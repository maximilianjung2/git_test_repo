# Schutz für interne Admin-Seiten im Root-Level.
# WICHTIG: nicht <FilesMatch> verwenden — das matcht den Dateinamen
# auch in Unterordnern, wodurch Training/wiki.php und
# Training/strava_connect.php ungewollt mitgeschützt würden
# (die haben ihre eigene Session-basierte Auth).
# Stattdessen <If> mit REQUEST_URI, anchored auf Root.
<If "%{REQUEST_URI} =~ m#^/(wiki|kilometer_debug|strava_connect|notify_test|termin_edit)\.php$#">
    AuthType Basic
    AuthName "Interner Bereich - Lauftreff"
    # Pfad ggf. an Hoster anpassen (siehe Wiki, Abschnitt 9):
    AuthUserFile /home/www/spvgg1879-lauftreff/htdocs/.htpasswd
    Require valid-user
</If>

# Token-Dateien niemals direkt ausliefern.
<FilesMatch "^strava_tokens\.json(\.bak)?$">
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# secrets.php niemals direkt ausliefern (nur per require einbinden).
<Files "secrets.php">
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

# .env-Dateien (Klartext-Credentials) niemals ausliefern.
# Greift auch für .env.example, .env.local etc.
<FilesMatch "^\.env">
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# .htpasswd niemals ausliefern.
<Files ".htpasswd">
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

# .htaccess selbst auch nicht.
<Files ".htaccess">
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>
